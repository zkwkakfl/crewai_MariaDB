# ---------------------------------------------------------------------------
# [.env.example] = 예시만. 실제 비밀 값은 `.env`에만.
# ---------------------------------------------------------------------------

# 프로파일(권장): 회사/집 PC 사양에 맞춰 로컬 전용 파일로 분리
# - `.env.home`   : 집(고성능) 설정
# - `.env.office` : 회사(저성능) 설정
# - `.env.local`  : 어떤 프로파일보다 최우선으로 덮어쓰는 로컬 오버라이드
# 위 파일들은 모두 `.gitignore`에 포함되어야 합니다(민감 정보 유출 방지).

# --- Ollama (기본) : 터미널에서 `ollama serve` 후 사용. API 키 불필요.
# SMD_USE_OLLAMA=true
# 로컬 주소 (기본 http://localhost:11434/v1 형태로 정규화됨)
# OLLAMA_HOST=http://localhost:11434
# `ollama list`에 나온 이름 (기본 qwen2.5-coder:3b — `ollama pull qwen2.5-coder:3b`)
# 콜론(:) 포함 시 따옴표 권장: OLLAMA_MODEL="qwen2.5-coder:3b"
# OLLAMA_MODEL=qwen2.5-coder:3b

# 한 줄로 모델 고정(선택, Ollama/클라우드 모두 가능)
# SMD_CREW_LLM=ollama/qwen2.5-coder:3b

# --- 클라우드만 쓸 때: SMD_USE_OLLAMA=false 후 아래 중 하나 ---
# GOOGLE_API_KEY=
# OPENAI_API_KEY=

# 선택: 스모크(--quick) 전용 모델 (미설정 시 위와 동일 기본)
# SMD_CREW_QUICK_MODEL=ollama/qwen2.5-coder:3b

# 선택: 부하 완화
# SMD_CREW_MAX_RPM=6
# SMD_AGENT_MAX_ITER=3
